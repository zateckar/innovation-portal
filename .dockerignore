# Dependencies
node_modules

# Build output
build
.svelte-kit

# Git
# .git is intentionally NOT excluded — the build pipeline reads
# `git rev-parse` to embed the commit SHA / branch into build-info so the
# admin UI can display exactly which commit is deployed. Excluding .git
# would force the build-info to fall back to "unknown" inside the container.
.gitignore

# IDE
.vscode
.idea
*.swp
*.swo

# Env files
.env
.env.*
!.env.example

# Database
data/
*.db
*.db-wal
*.db-shm

# OS
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*

# Test
coverage
.nyc_output

# Documentation
*.md
!README.md

# Misc
.npmrc

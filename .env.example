# Database
DATABASE_PATH=./data/innovation-radar.db

# Auth
SESSION_SECRET=your-super-secret-session-key-change-this-in-production

# Initial Admin (optional, creates admin user on first startup if no admin exists)
# INIT_ADMIN_EMAIL=admin@company.com
# INIT_ADMIN_PASSWORD=change-this-secure-password
# INIT_ADMIN_NAME=Admin User

# OIDC (optional, for corporate SSO)
# Supports any OpenID Connect compliant provider (Azure AD, Okta, Keycloak, Auth0, etc.)
# Example for Azure AD: https://login.microsoftonline.com/{tenant-id}/v2.0
# Example for Okta: https://dev-xxxxx.okta.com
# Example for Keycloak: https://keycloak.example.com/realms/{realm}
OIDC_ISSUER=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URI=http://localhost:5173/auth/callback

# AI - Google Gemini
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-3-flash-preview

# External build pipeline (Mamina) — optional alternative to the internal builder.
# When MAMINA_API_KEY is set, ideas with a completed spec gain a
# "Build with External Pipeline" option that runs the build via the Mamina REST API.
MAMINA_API_KEY=
# Base URL of the Mamina API (default shown). No trailing slash.
MAMINA_BASE_URL=https://www.mamina.net/api/v1
# Optional LiteLLM model id override for external runs (e.g. anthropic/claude-opus-4-7)
# MAMINA_MODEL=
# Hard budget cap in USD per external run (default 20)
MAMINA_MAX_BUDGET=20

# App
PORT=3000
PUBLIC_APP_URL=http://localhost:3000

# Log file path (relative to working directory, used by the Application Logs admin page)
# LOG_FILE=server.log

# Base Path (optional, for serving under a subpath e.g., /myapp)
# Set this at BUILD TIME to serve the app at http://hostname/basepath
# IMPORTANT: Requires rebuilding the application after changing!
# Examples: BASE_PATH=inno  or  BASE_PATH=/inno  (both work, will be normalized to /inno)
# BASE_PATH=

# Database
DATABASE_PATH=./data/innovation-radar.db

# Auth
SESSION_SECRET=your-super-secret-session-key-change-this-in-production

# Initial Admin (optional, creates admin user on first startup if no admin exists)
# INIT_ADMIN_EMAIL=admin@company.com
# INIT_ADMIN_PASSWORD=change-this-secure-password
# INIT_ADMIN_NAME=Admin User

# OIDC (optional, for corporate SSO)
# Supports any OpenID Connect compliant provider (Azure AD, Okta, Keycloak, Auth0, etc.)
# Example for Azure AD: https://login.microsoftonline.com/{tenant-id}/v2.0
# Example for Okta: https://dev-xxxxx.okta.com
# Example for Keycloak: https://keycloak.example.com/realms/{realm}
OIDC_ISSUER=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URI=http://localhost:5173/auth/callback

# AI - Google Gemini
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-3-flash-preview

# App
PORT=3000
PUBLIC_APP_URL=http://localhost:3000
